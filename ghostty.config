# 全般的な設定

## テーマ
## https://ghostty.org/docs/config/reference#theme
theme = GitHub Dark Default

## フォントファミリー
## https://ghostty.org/docs/config/reference#font-family
font-family = Menlo

## フォントサイズ
## https://ghostty.org/docs/config/reference#font-size
font-size = 14

# ---------------------------------------------------------------------------------------

# ウィンドウの設定

## ウィンドウ、タブ、スプリットの状態を保存して復元する
## https://ghostty.org/docs/config/reference#window-save-state
window-save-state = always

## 新しいタブは直前のタブの作業ディレクトリを引き継ぐ
## https://ghostty.org/docs/config/reference#tab-inherit-working-directory
tab-inherit-working-directory = true

## 新しいスプリットは直前のスプリットの作業ディレクトリを引き継ぐ
## https://ghostty.org/docs/config/reference#split-inherit-working-directory
split-inherit-working-directory = true

# ---------------------------------------------------------------------------------------

# フルスクリーンの設定

## 背景の透過率
## https://ghostty.org/docs/config/reference#background-opacity
background-opacity = 1

# ---------------------------------------------------------------------------------------

# スプリットの設定

## 未フォーカスのスプリットを暗くする
## https://ghostty.org/docs/config/reference#unfocused-split-opacity
unfocused-split-opacity = 0.55

## 未フォーカスのスプリットを黒で暗くする
## https://ghostty.org/docs/config/reference#unfocused-split-fill
unfocused-split-fill = #000000

## スプリットの区切り線を明るい緑で目立たせる
## https://ghostty.org/docs/config/reference#split-divider-color
split-divider-color = #39ff14

## 新しいスプリット
## https://ghostty.org/docs/config/keybind/reference#new_split
keybind = cmd+ctrl+h=new_split:left
keybind = cmd+ctrl+l=new_split:right
keybind = cmd+ctrl+j=new_split:down
keybind = cmd+ctrl+k=new_split:up

## スプリットの移動
## https://ghostty.org/docs/config/keybind/reference#goto_split
keybind = cmd+shift+h=goto_split:left
keybind = cmd+shift+l=goto_split:right
keybind = cmd+shift+j=goto_split:down
keybind = cmd+shift+k=goto_split:up

## スプリットのリサイズ
## https://ghostty.org/docs/config/keybind/reference#resize_split
keybind = cmd+alt+h=resize_split:left,20
keybind = cmd+alt+l=resize_split:right,20
keybind = cmd+alt+j=resize_split:down,20
keybind = cmd+alt+k=resize_split:up,20

## スプリットのズーム
## https://ghostty.org/docs/config/keybind/reference#toggle_split_zoom
keybind = cmd+shift+enter=toggle_split_zoom

## スプリットの均等化
## https://ghostty.org/docs/config/keybind/reference#equalize_splits
keybind = cmd+alt+equal=equalize_splits

## 現在のスプリット、タブ、ウィンドウを閉じる
## https://ghostty.org/docs/config/keybind/reference#close_surface
keybind = cmd+ctrl+w=close_surface

## 閉じたスプリット、タブ、ウィンドウを戻す
## https://ghostty.org/docs/config/keybind/reference#undo
keybind = cmd+z=undo
keybind = cmd+shift+z=redo

## プロンプト単位でスクロールバックを移動
## https://ghostty.org/docs/config/keybind/reference#jump_to_prompt
keybind = cmd+shift+[=jump_to_prompt:-1
keybind = cmd+shift+]=jump_to_prompt:1

# ---------------------------------------------------------------------------------------

# スクロールバックの設定

## 端末ごとのスクロールバック保持量
## https://ghostty.org/docs/config/reference#scrollback-limit
scrollback-limit = 10000000

## スクロールバー表示は macOS のシステム設定に従う
## https://ghostty.org/docs/config/reference#scrollbar
scrollbar = system

# ---------------------------------------------------------------------------------------

# クリップボードとマウスの設定

## 選択したテキストを自動でコピーする
## https://ghostty.org/docs/config/reference#copy-on-select
copy-on-select = true

## 右クリックではコンテキストメニューを開く
## https://ghostty.org/docs/config/reference#right-click-action
right-click-action = context-menu

## 危険そうな貼り付けには確認を出す
## https://ghostty.org/docs/config/reference#clipboard-paste-protection
clipboard-paste-protection = true

## bracketed paste 対応アプリでは貼り付けを安全扱いする
## https://ghostty.org/docs/config/reference#clipboard-paste-bracketed-safe
clipboard-paste-bracketed-safe = true

# ---------------------------------------------------------------------------------------

# シェル連携の設定

## 作業ディレクトリ継承やプロンプト単位の移動を有効にする
## https://ghostty.org/docs/config/reference#shell-integration
shell-integration = detect

# ---------------------------------------------------------------------------------------

# 終了確認の設定

## 実行中プロセスがあるサーフェスを閉じる時に確認する
## https://ghostty.org/docs/config/reference#confirm-close-surface
confirm-close-surface = true

# ---------------------------------------------------------------------------------------

# 通知の設定

## ベル時に macOS のアラート音と視覚的な通知を使う
## https://ghostty.org/docs/config/reference#bell-features
bell-features = system,attention,title

# ---------------------------------------------------------------------------------------

# macOS 固有の設定

## Option キーを Alt として扱う
## https://ghostty.org/docs/config/reference#macos-option-as-alt
macos-option-as-alt = true

# ---------------------------------------------------------------------------------------

# クイックターミナルの設定

## クイックターミナルの場所
## https://ghostty.org/docs/config/reference#quick-terminal-position
quick-terminal-position = "top"

## クイックターミナルのサイズ
## https://ghostty.org/docs/config/reference#quick-terminal-size
quick-terminal-size = 60%

## クイックターミナルが表示されるディスプレイ
## https://ghostty.org/docs/config/reference#quick-terminal-screen
quick-terminal-screen = "macos-menu-bar"

## フォーカスが外れた時にクイックターミナルを自動で隠す
## https://ghostty.org/docs/config/reference#quick-terminal-autohide
quick-terminal-autohide = true

## クイックターミナルが表示されるまでの時間
## https://ghostty.org/docs/config/reference#quick-terminal-animation-duration
quick-terminal-animation-duration = 0.3

## クイックターミナル表示非表示のキーバインド
## https://ghostty.org/docs/config/keybind/reference#toggle_quick_terminal
keybind = global:cmd+backquote=toggle_quick_terminal
